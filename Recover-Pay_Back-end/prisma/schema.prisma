generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id          String              @id @default(cuid())
  name        String
  email       String?             @unique
  clerkUserId String?             @unique
  apiKey      String              @unique
  // SaaS plan — "free" during hackathon, wire up billing after
  plan        String              @default("free")
  planActive  Boolean             @default(true)
  plans       Plan[]
  nombaConfig TenantNombaConfig?
  createdAt   DateTime            @default(now())
}

// Tenant's own Nomba merchant credentials
// Stored with AES-256 encryption for clientSecret and webhookSecret
model TenantNombaConfig {
  id                     String   @id @default(cuid())
  tenantId               String   @unique
  tenant                 Tenant   @relation(fields: [tenantId], references: [id])
  nombaAccountId         String   // parent account ID — goes in accountId header
  nombaSubAccountId      String   // sub-account ID — goes in order.accountId body
  nombaClientId          String   // client ID for OAuth
  clientSecretEncrypted  String   // AES-256 encrypted client secret
  webhookSecretEncrypted String?  // AES-256 encrypted webhook secret (optional)
  baseUrl                String   @default("https://sandbox.nomba.com")
  verified               Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Plan {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  name          String
  amount        Decimal        @db.Decimal(12, 2)
  currency      String         @default("NGN")
  interval      String
  trialDays     Int            @default(0)
  archived      Boolean        @default(false)
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
}

model Customer {
  id            String         @id @default(cuid())
  email         String         @unique
  tokenKey      String?
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
}

model Subscription {
  id                 String    @id @default(cuid())
  customerId         String
  customer           Customer  @relation(fields: [customerId], references: [id])
  planId             String
  plan               Plan      @relation(fields: [planId], references: [id])
  status             String
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingDate    DateTime
  dunningAttempt     Int       @default(0)
  invoices           Invoice[]
  createdAt          DateTime  @default(now())
}

model Invoice {
  id                     String                  @id @default(cuid())
  subscriptionId         String
  subscription           Subscription            @relation(fields: [subscriptionId], references: [id])
  status                 String
  amountDue              Decimal                 @db.Decimal(12, 2)
  amountPaid             Decimal                 @default(0) @db.Decimal(12, 2)
  periodStart            DateTime
  periodEnd              DateTime
  chargeAttempts         ChargeAttempt[]
  virtualAccountAttempts VirtualAccountAttempt[]
  createdAt              DateTime                @default(now())
}

model ChargeAttempt {
  id             String   @id @default(cuid())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id])
  orderReference String   @unique
  status         String
  message        String?
  createdAt      DateTime @default(now())
}

model VirtualAccountAttempt {
  id             String   @id @default(cuid())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id])
  accountRef     String   @unique
  accountNumber  String?
  bankName       String?
  expectedAmount Decimal  @db.Decimal(12, 2)
  status         String   @default("pending")
  expiryDate     DateTime
  createdAt      DateTime @default(now())
}

model WebhookEvent {
  id        String   @id @default(cuid())
  requestId String   @unique
  type      String
  raw       Json
  createdAt DateTime @default(now())
}
