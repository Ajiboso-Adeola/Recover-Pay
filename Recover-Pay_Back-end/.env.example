# =============================================
# RECOVERPAY — ENVIRONMENT VARIABLES
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it is in .gitignore

# --- NEON DATABASE ---
# Pooled connection — used by the app at runtime
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=10

# Direct connection — used by Prisma CLI for migrations (run locally only)
DIRECT_URL=postgresql://user:password@ep-xxx-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- UPSTASH REDIS ---
REDIS_URL=rediss://default:your-password@your-redis.upstash.io:6379

# --- NOMBA API (TEST credentials only — never use LIVE during hackathon) ---
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_ACCOUNT_ID=your-nomba-account-id
NOMBA_SUB_ACCOUNT_ID=your-nomba-sub-account-id
NOMBA_CLIENT_ID=your-nomba-client-id
NOMBA_CLIENT_SECRET=your-nomba-client-secret

# --- WEBHOOK ---
# Provided by Nomba hackathon team — do not change
NOMBA_WEBHOOK_SECRET=your-nomba-webhook-secret

# --- APP ---
# Your deployed Render URL (no trailing slash)
# After deploying to Render, update this and redeploy
APP_URL=https://recoverpay.onrender.com
PORT=3000

# --- BILLING SCHEDULER ---
# How often the scheduler checks for subscriptions due
# 60000  = 1 minute  (use this during demo recording)
# 3600000 = 1 hour   (use this for real deployment)
BILLING_CYCLE_INTERVAL_MS=3600000

# --- ENCRYPTION ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=your64hexcharencryptionkeyhere00000000000000000000000000000000

# --- CLERK (backend) ---
CLERK_SECRET_KEY=your-clerk-secret-key

# --- FRONTEND ---
FRONTEND_URL=https://recover-pay.vercel.app


RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=RecoverPay <noreply@yourdomain.com>