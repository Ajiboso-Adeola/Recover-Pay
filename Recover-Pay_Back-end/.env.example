# =============================================
# RECOVERPAY — ENVIRONMENT VARIABLES
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it is in .gitignore
CLERK_SECRET_KEY=

# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL=

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL=
# --- UPSTASH REDIS ---
REDIS_URL=
# --- NOMBA API (TEST credentials only — never use LIVE during hackathon) ---
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_ACCOUNT_ID=your_account_id_here
NOMBA_SUB_ACCOUNT_ID=your_sub_account_id_here
NOMBA_CLIENT_ID=your_client_id_here
NOMBA_CLIENT_SECRET=your_client_secret_here

# --- WEBHOOK ---
# Provided by Nomba hackathon team — do not change
NOMBA_WEBHOOK_SECRET=NombaHackathon2026

# --- APP ---
# Your deployed Render URL (no trailing slash)
# After deploying to Render, update this and redeploy
APP_URL=https://recoverpay-nomba-webhook.onrender.com/v1/webhooks/nomba

PORT=3000

# --- BILLING SCHEDULER ---
# How often the scheduler checks for subscriptions due
# 60000  = 1 minute  (use this during demo recording)
# 3600000 = 1 hour   (use this for real deployment)
BILLING_CYCLE_INTERVAL_MS=3600000
