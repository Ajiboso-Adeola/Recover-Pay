# =============================================
# RECOVERPAY FRONTEND — ENVIRONMENT VARIABLES
# =============================================
# Copy to .env.local and fill in your values

# --- CLERK AUTH ---
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Clerk redirect URLs — do not change these
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- BACKEND API ---
# Your RecoverPay backend URL
# Development: http://localhost:3000
# Production: your Render URL after deployment
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- APP ---
# Your deployed frontend URL (for sharing + docs)
# Leave as localhost during development
NEXT_PUBLIC_APP_URL=http://localhost:3001
